# Public bridge auth
BRIDGE_API_KEY=replace_me_with_long_random_string

# App
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# Zotero upstream
ZOTERO_API_BASE=https://api.zotero.org
ZOTERO_API_VERSION=3
ZOTERO_LIBRARY_TYPE=user
ZOTERO_LIBRARY_ID=123456
ZOTERO_API_KEY=replace_me_with_zotero_write_key

# Optional external discovery
OPENALEX_API_BASE=https://api.openalex.org
OPENALEX_API_KEY=

# Defaults
DEFAULT_COLLECTION_KEY=
DEFAULT_NOTE_TAG_PREFIX=zbridge
DEFAULT_CITATION_STYLE=apa
DEFAULT_CITATION_LOCALE=en-US
FULLTEXT_DEFAULT_MAX_CHARS=8000
FULLTEXT_MAX_CHARS_HARD_LIMIT=12000
ENABLE_LOCAL_FULLTEXT_CACHE=true
LOCAL_FULLTEXT_CACHE_DIR=.cache/fulltext

# Limits
MAX_ACTION_REQUEST_CHARS=100000
MAX_UPLOAD_FILE_MB=15

# Optional: local relay phase 2
ENABLE_LOCAL_RELAY=false
RELAY_SHARED_TOKEN=
